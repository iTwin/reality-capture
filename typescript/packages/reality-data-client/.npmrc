# Run lifecycle scripts (postinstall etc.) sequentially.
# Without this, two copies of @itwin/certa's postinstall run concurrently
# (once as a direct devDep, once transitively via @itwin/oidc-signin-tool),
# both invoking `playwright install chromium` at the same time and deadlocking
# on playwright's __dirlock file.
child-concurrency=1
